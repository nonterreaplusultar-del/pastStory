{
  "name": "paststory",
  "version": "1.0.0",
  "description": "--- metaLinks:   alternates:     - https://app.gitbook.com/s/2AwfWOGBWBxQmyvHedqW/ ---",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build:solar": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview --host 0.0.0.0",
    "test": "npm run check:structure",
    "check:structure": "node -e \"const fs=require('fs'); const required=['README.md','SUMMARY.md','2017','2018','2020','2024','2025','2026','drafts']; const missing=required.filter((path)=>!fs.existsSync(path)); if(missing.length){console.error('Missing required paths: '+missing.join(', ')); process.exit(1);} console.log('Structure check passed.');\"",
    "check:privacy": "bash scripts/check-privacy.sh",
    "check:build": "npm run build",
    "check:prepublish": "bash scripts/prepublish.sh",
    "serve": "honkit serve . _book --port 4000",
    "build": "honkit build . _book",
    "clean": "node -e \"const fs=require('fs'); const path=require('path'); const target=path.resolve('_book'); const cwd=process.cwd(); if(target!==path.join(cwd,'_book')){throw new Error('Refusing to clean unexpected path: '+target);} fs.rmSync(target,{recursive:true,force:true}); console.log('Cleaned _book.');\"",
    "ai:status": "bash scripts/ai-status.sh",
    "ai:precheck": "bash scripts/ai-precheck.sh",
    "daily": "bash scripts/daily-flow.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nonterreaplusultar-del/pastStory.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/nonterreaplusultar-del/pastStory/issues"
  },
  "homepage": "https://github.com/nonterreaplusultar-del/pastStory#readme",
  "devDependencies": {
    "@dogatana/honkit-plugin-back-to-top-button": "^1.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.7.0",
    "gitbook-plugin-chollapse": "^1.0.1",
    "honkit": "^6.1.7",
    "typescript": "^6.0.3",
    "vite": "^6.4.2"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "three": "^0.184.0"
  }
}
